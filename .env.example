# Copie para .env — nunca commitar o .env real (lição CarToken: secrets fora do repo).
DATABASE_URL=postgres://ditofeito:senha@localhost:5432/ditofeito
POSTGRES_PASSWORD=senha
NODE_ENV=development
PORT=3000
# Vazio = modo dev (auth.ts aceita qualquer captchaToken em vez de validar no Cloudflare).
TURNSTILE_SECRET_KEY=
# Cifra a API key de e-mail salva em /admin/email — gere com `openssl rand -hex 32`.
# Sem essa var, a tela funciona mas salvar uma chave nova falha.
EMAIL_CONFIG_KEY=
