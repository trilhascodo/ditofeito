# Copie para infra/.env NA VPS — nunca commitar. Lido por `docker compose --env-file infra/.env`.
POSTGRES_PASSWORD=troque-por-uma-senha-forte
# Porta do HOST onde a API escuta (127.0.0.1 apenas — nginx faz o proxy_pass).
# Em VPS compartilhada, escolha uma porta livre (ver infra/nginx/README.md).
API_HOST_PORT=3000
WEB_ORIGIN=https://ditofeito.com
APP_BASE_URL=https://ditofeito.com
# Fallback legado (usado só se ninguém configurar nada em /admin/email).
# Vazio = modo dev (auth.ts loga o e-mail de verificação no console em vez de enviar).
RESEND_API_KEY=
EMAIL_FROM=DitoFeito <nao-responda@ditofeito.com>
# Cifra a API key de e-mail salva pelo painel /admin/email (email_settings.
# api_key_encrypted) -- gere com `openssl rand -hex 32`. Sem essa var, a tela
# ainda funciona pra configurar remetente, mas salvar uma chave nova falha
# (o fallback RESEND_API_KEY acima continua valendo nesse caso).
EMAIL_CONFIG_KEY=
# Cloudflare Dashboard > Turnstile > criar site > "Secret key" (vazio = captcha sempre passa).
TURNSTILE_SECRET_KEY=
# Mesmo site do Turnstile acima, "Site key" (pública — deploy-run.sh injeta
# no build do frontend via VITE_TURNSTILE_SITE_KEY; vazio = widget não aparece).
VITE_TURNSTILE_SITE_KEY=
# Google Cloud Console > APIs & Services > Credentials > "Create OAuth client
# ID" > Web application. Authorized JavaScript origin = https://ditofeito.com
# (sem callback/redirect URI — o fluxo usa Google Identity Services, sem
# redirect). Client ID é público por natureza: mesmo valor aqui e em
# VITE_GOOGLE_CLIENT_ID abaixo (deploy-run.sh injeta os dois). Vazio = botão
# "Continuar com Google" some do login/cadastro.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
# Remote do rclone (não é lido pelo docker compose — só por infra/scripts/
# backup.sh e restore-test.sh, direto do host). Configurar rclone.conf
# separadamente (~/.config/rclone/rclone.conf na VPS) — ver runbook.
BACKUP_BUCKET=r2:ditofeito-backups
