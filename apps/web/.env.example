# Copie para apps/web/.env.local pra dev, ou defina no ambiente de build em produção.
# Site key do Turnstile (pública por natureza — ok expor no bundle). Vazio = o
# widget de captcha some do cadastro e o backend também aceita sem validar
# (ver TURNSTILE_SECRET_KEY vazio em infra/.env.example).
VITE_TURNSTILE_SITE_KEY=
# Client ID OAuth do Google (público por natureza — mesmo valor que
# GOOGLE_CLIENT_ID no backend, ver infra/.env.example). Vazio = o botão
# "Continuar com Google" some do login/cadastro.
VITE_GOOGLE_CLIENT_ID=
