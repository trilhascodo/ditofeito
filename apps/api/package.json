{
  "name": "@ditofeito/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/routers/_app.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ditofeito/core": "workspace:*",
    "@ditofeito/db": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "@trpc/server": "^11.0.0",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "node-cron": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.4.1",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
